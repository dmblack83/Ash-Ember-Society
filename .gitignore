# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code worktree state — runtime locks/scratch from `claude` CLI
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data scripts / seed files
/scripts/*.json

# service worker — generated by Serwist at build time from app/sw.ts
# (see serwist.config.mjs). Source of truth is app/sw.ts.
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map

# playwright e2e tests — runtime artifacts only; specs live under
# tests/e2e/ and ARE committed.
/test-results
/playwright-report
/playwright/.auth
/blob-report
/playwright/.cache
